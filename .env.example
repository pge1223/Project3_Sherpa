# ============================================
# .env.example
# 이 파일은 "어떤 값이 필요한지"만 보여줍니다.
# 실제 값은 이 파일을 복사해 .env로 만들고 채워 넣으세요.
# .env는 절대 git에 커밋하지 마세요 (.gitignore에 이미 포함됨).
# 실제 값 전달은 팀 비공개 채널(노션 비공개 페이지 / 1Password 등)로.
# ============================================

# --- LLM ---
PERSO_API_KEY=

# --- MongoDB (NCP) ---
MONGODB_URI=
MONGODB_DB_NAME=

# --- NCP 서버/인프라 ---
NCP_ACCESS_KEY=
NCP_SECRET_KEY=
NCP_SERVER_HOST=

# --- 외부 데이터 소스 ---
KSTARTUP_API_KEY=
GIUP_MADANG_API_KEY=

# --- 모바일(Expo) 공개 변수: EXPO_PUBLIC_ 접두사 붙은 것만 클라이언트에 노출됨 ---
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# --- RAG 평가 ---
RAGAS_EVAL_MODE=local
