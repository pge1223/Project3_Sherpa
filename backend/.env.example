# backend/.env 템플릿 — 실제 값은 backend/.env에 채우고 Git에는 올리지 않는다.
# 레포 루트 .env.example과는 별개 파일이다: 루트 .env는 scripts/RAG 쪽 공통 설정,
# backend/.env는 backend/app/config.py(Settings)가 읽는 백엔드 전용 설정이다
# (backend/app/config.py의 _ENV_FILE은 항상 backend/.env를 가리킨다).

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=ai_review_board

OPENAI_API_KEY=

LLM_PROFILE=dev

# 개발용 "아이디어 발전 회의" 프리뷰 API(POST /ideation-preview) 활성화 여부. true로 켜면
# 실제 OpenAI 호출이 들어간다 — 로컬 개발/검증 용도로만 켜고 운영 환경에서는 false로 둔다.
ENABLE_IDEATION_PREVIEW=false

# 대화형 아이디어 회의의 실시간 스트리밍 응답(POST /ideation-conversation/{session_id}/
# reply/stream) 활성화 여부. ENABLE_IDEATION_PREVIEW=true가 먼저 켜져 있어야 하며, 이 값이
# false로 명시하면 스트리밍 엔드포인트만 404를 반환하고 기존 동기식 /reply는 그대로 동작한다.
ENABLE_IDEATION_STREAMING=true

# 아이디어 회의 개발 진단 로그(화자/응답 대상/최종 spoken_text/라우팅). 사용자 입력이
# 제한 길이로 포함될 수 있으므로 로컬 디버깅 때만 켠다.
ENABLE_IDEATION_TRACE_LOGS=false
IDEATION_TRACE_CONTENT_MAX_CHARS=500
IDEATION_TRACE_STREAM_DELTAS=false

# Phase 1 "Shadow Deterministic Evidence Planner" — discussion 턴에서 규칙 기반 evidence
# planner를 그림자(shadow) 모드로 실행할지 여부. 꺼져 있으면(기본값) planner를 아예 주입하지
# 않아 기존 동작과 100% 동일하다. 켜져도 이 단계에서는 결과가 trace 로그로만 기록된다.
ENABLE_IDEATION_EVIDENCE_PLANNER_SHADOW=false

# Phase 2 "Active Evidence Injection" — discussion(planning_expert/dev_expert) 발언 prompt와
# claim grounding에 shadow planner의 선택 결과를 실제로 사용할지 여부. 위 SHADOW 플래그와
# 별개다(SHADOW=로그만, 이 플래그=실제 사용). 꺼져 있으면(기본값) 기존 retrieved 전체 주입
# 경로와 100% 동일하다.
ENABLE_IDEATION_EVIDENCE_PLANNER_DISCUSSION=false

# RAG 품질 오프라인 평가 도구(ai/rag/evaluation/rag_quality)의 LLM-as-judge 전용 모델.
# 실제 답변을 생성하는 모델과 분리해 둔다(기본값 gpt-4o-mini).
EVAL_LLM_MODEL=gpt-4o-mini

# LangSmith 트레이싱(관측성, 2026-07-23) - LangGraph 노드(위원 리뷰/위원장 종합/아이디어
# 회의)와 backend 라우트의 OpenAI 호출을 LangSmith 대시보드에서 추적할지 여부. true로
# 켜려면 LANGSMITH_API_KEY도 채워야 한다(https://smith.langchain.com 에서 발급). 기본값
# false — 꺼져 있으면 기존 동작과 100% 동일하고 어떤 외부 호출도 추가되지 않는다.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-review-board

# NCP (Naver Cloud Platform)
NCP_ACCESS_KEY=
NCP_SECRET_KEY=
NCP_BUCKET_NAME=

# HWP/HWPX -> PDF 변환 (ai/rag/converters, LibreOffice headless). 자세한 설치/확인
# 절차는 backend/README.md의 "HWP/HWPX 업로드(LibreOffice 변환) 설정" 참고.
HWP_CONVERSION_ENABLED=true

# 비워두면 PATH에서 soffice/libreoffice를 찾고,
# Windows에서는 코드가 기본 설치 경로도 최후 수단으로 확인한다.
# 값을 명시했는데 그 경로에 실행 파일이 없으면 PATH로 조용히 폴백하지 않고
# unavailable로 처리한다(GET /health에서 확인 가능) — 운영 서버라면 배포 환경변수나
# secret/config 관리 기능으로 절대 경로를 명시하는 걸 권장한다.
HWP_CONVERTER_EXECUTABLE=

# Windows에서 명시적으로 지정할 경우:
# HWP_CONVERTER_EXECUTABLE=C:\Program Files\LibreOffice\program\soffice.exe

# Linux에서 명시적으로 지정할 경우:
# HWP_CONVERTER_EXECUTABLE=/usr/bin/soffice

HWP_CONVERSION_TIMEOUT_SECONDS=60
HWP_CONVERSION_MAX_FILE_SIZE_BYTES=52428800
HWP_CONVERSION_KEEP_FILES=false

# 비워두면 시스템 임시 디렉터리 사용
HWP_CONVERSION_TEMP_DIR=
