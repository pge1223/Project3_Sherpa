{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://review-board.local/contracts/review_output.schema.json",
  "title": "AI Review Board Output",
  "$comment": "v2.2.0 (팀 승인·적용, 가은/경이 확인). v2.1.0에서 chair_summary/top_revisions를 top-level required에서 빼고 nullable로 완화 — 위원장 종합을 backend가 리뷰+채점 이후 백그라운드로 늦게 돌릴 수 있게 되면서, 그 사이엔 null인 문서(status=synthesizing)가 정상 상태가 됐다(document_id/title이 이미 nullable인 것과 같은 패턴). 선택 필드 완화라 하위 호환. v2.1.0에서 선택 필드 similar_success_cases(RAG-006 유사사례, reference_only) 추가 + schema_version enum화(하위호환). 개정 배경: review_output.v2.1.proposal.md. v2.0.0 배경: review_output.v2.proposal.md",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "meeting_id",
    "project_id",
    "status",
    "domain",
    "rubric",
    "reviewer_results",
    "score_result",
    "evidence",
    "media_script"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["2.0.0", "2.1.0", "2.2.0"] },
    "meta": { "$ref": "#/$defs/meta" },
    "meeting_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "document_id": { "type": ["string", "null"] },
    "title": { "type": ["string", "null"] },
    "status": {
      "type": "string",
      "enum": ["pending", "retrieving", "reviewing", "scoring", "synthesizing", "completed", "failed"]
    },
    "domain": {
      "type": "string",
      "enum": ["startup", "government_support", "competition", "proposal", "general"]
    },
    "rubric": { "$ref": "#/$defs/rubric" },
    "reviewer_results": { "type": "array", "items": { "$ref": "#/$defs/reviewerResult" } },
    "score_result": { "$ref": "#/$defs/scoreResult" },
    "chair_summary": { "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/chairSummary" }] },
    "top_revisions": { "type": ["array", "null"], "maxItems": 5, "items": { "$ref": "#/$defs/revision" } },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
    "media_script": { "type": "array", "items": { "$ref": "#/$defs/mediaLine" } },
    "similar_success_cases": {
      "type": ["object", "null"],
      "$comment": "v2.1.0 신설(선택). RAG-006 유사 성공사례 검색 결과(용준 SimilarCaseSearchResponse.model_dump()). 평가 점수 근거가 아니라 비교·개선용 참고 자료(reference_only). 내부 구조는 ai/rag/similar_cases가 소유하며 회의 계약은 재검증하지 않는다(pass-through). RAG-006 미실행 시 null 또는 필드 생략."
    },
    "error": { "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/error" }] }
  },
  "$defs": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mock": { "type": "boolean" },
        "created_at": { "type": "string" },
        "language": { "type": "string" }
      }
    },
    "rubric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rubric_id", "total_max_score", "criteria"],
      "properties": {
        "rubric_id": { "type": "string" },
        "source_document_id": { "type": ["string", "null"] },
        "total_max_score": { "type": "number", "exclusiveMinimum": 0 },
        "criteria": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/rubricCriterion" } }
      }
    },
    "rubricCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterion_id", "criterion_name", "max_score", "required"],
      "properties": {
        "criterion_id": { "type": "string" },
        "criterion_name": { "type": "string" },
        "max_score": { "type": "number", "exclusiveMinimum": 0 },
        "weight": { "type": ["number", "null"], "minimum": 0 },
        "required": { "type": "boolean" },
        "description": { "type": ["string", "null"] }
      }
    },
    "reviewerResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["persona_id", "role", "summary", "rubric_scores", "confidence"],
      "properties": {
        "review_id": { "type": "string" },
        "persona_id": { "type": "string" },
        "persona_name": { "type": "string" },
        "role": { "type": "string" },
        "review_round": { "type": "integer", "minimum": 1 },
        "summary": { "type": "string" },
        "rubric_scores": { "type": "array", "items": { "$ref": "#/$defs/rubricScore" } },
        "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
        "cross_reviews": { "type": "array", "items": { "$ref": "#/$defs/crossReview" } },
        "out_of_scope": { "type": "array", "items": { "$ref": "#/$defs/outOfScope" } }
      }
    },
    "rubricScore": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criterion_id",
        "criterion_name",
        "score",
        "max_score",
        "judgment",
        "strengths",
        "issues",
        "suggestions",
        "evidence_ids",
        "evidence_status"
      ],
      "properties": {
        "criterion_id": { "type": "string" },
        "criterion_name": { "type": "string" },
        "score": { "type": "number", "minimum": 0 },
        "max_score": { "type": "number", "exclusiveMinimum": 0 },
        "judgment": {
          "type": "string",
          "enum": ["strong", "acceptable", "needs_improvement", "critical_risk"]
        },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "issues": { "type": "array", "items": { "type": "string" } },
        "suggestions": { "type": "array", "items": { "type": "string" } },
        "evidence_ids": { "type": "array", "items": { "type": "string" } },
        "evidence_status": {
          "type": "string",
          "enum": ["sufficient", "partial", "insufficient"]
        }
      }
    },
    "crossReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_persona_id", "relation", "comment"],
      "properties": {
        "target_persona_id": { "type": "string" },
        "relation": { "type": "string", "enum": ["supplement", "challenge", "support"] },
        "target_criterion_id": { "type": ["string", "null"] },
        "comment": { "type": "string" },
        "evidence_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "outOfScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topic", "reason"],
      "properties": {
        "topic": { "type": "string" },
        "reason": { "type": "string" },
        "handoff_persona_id": { "type": ["string", "null"] }
      }
    },
    "scoreResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_score",
        "max_score",
        "score_label",
        "calculation_version",
        "calculation_method",
        "breakdown"
      ],
      "properties": {
        "total_score": { "type": "number", "minimum": 0 },
        "max_score": { "type": "number", "exclusiveMinimum": 0 },
        "score_label": { "type": "string", "const": "evaluation_criteria_alignment" },
        "calculation_version": { "type": "string" },
        "calculation_method": {
          "type": "string",
          "enum": ["criterion_owner", "weighted_average"]
        },
        "breakdown": { "type": "array", "items": { "$ref": "#/$defs/scoreBreakdown" } },
        "penalties": { "type": "array", "items": { "$ref": "#/$defs/penalty" } }
      }
    },
    "scoreBreakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterion_id", "raw_score", "max_score", "penalty"],
      "properties": {
        "criterion_id": { "type": "string" },
        "raw_score": { "type": "number" },
        "max_score": { "type": "number", "exclusiveMinimum": 0 },
        "weight": { "type": ["number", "null"], "minimum": 0 },
        "weighted_score": { "type": ["number", "null"] },
        "penalty": { "type": "number", "default": 0 },
        "source_review_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "penalty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "amount", "reason"],
      "properties": {
        "type": { "type": "string", "enum": ["missing_required", "other"] },
        "criterion_id": { "type": ["string", "null"] },
        "amount": { "type": "number", "minimum": 0 },
        "reason": { "type": "string" }
      }
    },
    "chairSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chair_id", "overall_assessment", "consensus", "disagreements"],
      "properties": {
        "chair_id": { "type": "string" },
        "overall_assessment": { "type": "string" },
        "consensus": { "type": "array", "items": { "type": "string" } },
        "disagreements": { "type": "array", "items": { "$ref": "#/$defs/disagreement" } },
        "top_strengths": { "type": "array", "items": { "type": "string" } },
        "top_risks": { "type": "array", "items": { "type": "string" } },
        "final_decision": { "type": ["string", "null"] },
        "decision_note": { "type": ["string", "null"] }
      }
    },
    "disagreement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["topic", "positions", "chair_resolution"],
      "properties": {
        "topic": { "type": "string" },
        "positions": { "type": "array", "items": { "type": "string" } },
        "chair_resolution": { "type": "string" }
      }
    },
    "revision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["priority", "title", "reason", "target", "action", "evidence_ids"],
      "properties": {
        "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
        "title": { "type": "string" },
        "reason": { "type": "string" },
        "target": { "type": "string" },
        "action": { "type": "string" },
        "related_criteria": { "type": "array", "items": { "type": "string" } },
        "evidence_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "chunk_id", "document_name", "text", "score"],
      "properties": {
        "evidence_id": { "type": "string" },
        "chunk_id": { "type": "string" },
        "document_name": { "type": "string" },
        "source_type": {
          "type": ["string", "null"],
          "enum": ["submission", "notice", "criteria", null]
        },
        "page": { "type": ["integer", "null"], "minimum": 1 },
        "slide": { "type": ["integer", "null"], "minimum": 1 },
        "section": { "type": ["string", "null"] },
        "text": { "type": "string" },
        "quote": { "type": ["string", "null"] },
        "relevance": { "type": ["string", "null"] },
        "score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "mediaLine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["speaker_id", "speaker_name", "order", "text", "emotion"],
      "properties": {
        "speaker_id": { "type": "string" },
        "speaker_name": { "type": "string" },
        "order": { "type": "integer", "minimum": 1 },
        "text": { "type": "string" },
        "emotion": {
          "type": "string",
          "enum": ["neutral", "serious", "supportive", "concerned", "confident"]
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": { "type": ["object", "null"] }
      }
    }
  }
}
